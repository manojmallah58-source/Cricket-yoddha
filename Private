Q1. Import a CSV dataset into R. Display the structure, first 10 rows, and summary of the dataset. Handle missing values.
# Import CSV file
data <- read.csv("data.csv")

# Display structure of dataset
str(data)

# Display first 10 rows
head(data, 10)

# Summary of dataset
summary(data)

# Replace missing values with mean (for numeric columns)
data$Age[is.na(data$Age)] <- mean(data$Age, na.rm = TRUE)
data$Salary[is.na(data$Salary)] <- mean(data$Salary, na.rm = TRUE)


Q2. Create a dataset from an Excel file. Apply conditional filtering and sort data.


# Install package
install.packages("readxl")

# Load library
library(readxl)

# Import Excel file
data <- read_excel("data.xlsx")

# Filter records where Salary > 50000
filtered_data <- data[data$Salary > 50000, ]

# Sort data in descending order
sorted_data <- filtered_data[order(-filtered_data$Salary), ]

# Display result
sorted_data








