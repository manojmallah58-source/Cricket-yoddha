Write a program is java to demonstrate Boolean value ?


public class BooleanDemo {
    public static void main(String[] args) {
        boolean isJavaFun = true;
        boolean isSkyBlue = true;
        boolean isEarthFlat = false;

        System.out.println("Java is fun: " + isJavaFun);
        System.out.println("Sky is blue: " + isSkyBlue);
        System.out.println("Earth is flat: " + isEarthFlat);

        // Comparison se boolean value nikalna
        int a = 10;
        int b = 20;
        boolean result = (a < b); 

        System.out.println("Is 10 less than 20? " + result);
    }
}


